<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/colorSurface"
    app:cardCornerRadius="14dp" app:cardElevation="0dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp">
        <LinearLayout android:layout_width="70dp" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:id="@+id/tvStartTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="09:00" android:textColor="@color/colorPrimary" android:textSize="15sp" android:textStyle="bold" />
            <TextView android:id="@+id/tvEndTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10:30" android:textColor="@color/colorTextSecondary" android:textSize="12sp" />
        </LinearLayout>
        <View android:layout_width="3dp" android:layout_height="match_parent" android:layout_marginEnd="12dp" android:background="@color/colorPrimary" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvSubject" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Matematika" android:textColor="@color/colorOnBackground" android:textSize="15sp" android:textStyle="bold" />
            <TextView android:id="@+id/tvRoom" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/colorTextSecondary" android:textSize="13sp" />
            <TextView android:id="@+id/tvProfessor" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/colorTextSecondary" android:textSize="12sp" />
        </LinearLayout>
        <ImageButton android:id="@+id/btnDeleteSchedule" android:layout_width="32dp" android:layout_height="32dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_delete" android:tint="#BDBDBD" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>