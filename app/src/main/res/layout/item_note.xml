<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/noteCard"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="14dp" app:cardElevation="0dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:id="@+id/tvNoteTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Naslov" android:textColor="@color/colorOnBackground" android:textSize="15sp" android:textStyle="bold" />
            <ImageButton android:id="@+id/btnDeleteNote" android:layout_width="24dp" android:layout_height="24dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_delete" android:tint="#9E9E9E" />
        </LinearLayout>
        <TextView android:id="@+id/tvNoteContent" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:textColor="@color/colorOnBackground" android:textSize="13sp" android:maxLines="5" android:ellipsize="end" />
        <TextView android:id="@+id/tvNoteDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textColor="@color/colorTextSecondary" android:textSize="11sp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>