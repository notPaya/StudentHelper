<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/colorSurface"
    app:cardCornerRadius="14dp" app:cardElevation="0dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="16dp">
        <LinearLayout android:id="@+id/layoutCountdown" android:layout_width="60dp" android:layout_height="60dp" android:gravity="center" android:orientation="vertical" android:layout_marginEnd="12dp" android:background="@drawable/circle_badge">
            <TextView android:id="@+id/tvDaysCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5" android:textColor="@color/white" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="dana" android:textColor="@color/white" android:textSize="9sp" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvExamSubject" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Matematika" android:textColor="@color/colorOnBackground" android:textSize="16sp" android:textStyle="bold" />
            <TextView android:id="@+id/tvExamDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/colorTextSecondary" android:textSize="13sp" />
            <TextView android:id="@+id/tvExamNote" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/colorTextSecondary" android:textSize="12sp" android:maxLines="2" android:ellipsize="end" />
        </LinearLayout>
        <ImageButton android:id="@+id/btnDeleteExam" android:layout_width="32dp" android:layout_height="32dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_delete" android:tint="#BDBDBD" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>